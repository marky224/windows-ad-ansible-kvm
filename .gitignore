# Local-only files — design docs, handoff prompts, anything not for distribution
_private/
.claude/

# Ansible
*.retry
.vault-pass
.vault_pass
ansible.log

# Rendered seed-ISO contents (per-VM, generated)
ansible/files/rendered/
ansible/files/*-seed.iso

# Microsoft-distributed binary blobs (operator fetches once via _private/scripts/sct-fetch.sh).
# Version + SHA256 are pinned in ansible/files/sct/.version, which IS committed.
ansible/files/sct/*.zip

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Editor / OS
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Local logs
logs/
*.log

# Local override files (per-user)
inventory/local.yml
group_vars/local.yml
# Per-host overrides for the KVM host running this playbook; copy from .example.
ansible/inventory/host_vars/localhost.yml

# VM data should NEVER be in this repo — it lives outside, at $HOME/vm-lab by default.
# But just in case:
*.qcow2
*.iso
disks/
seed-iso/
backups/
snapshots/
