#cloud-config
# Rendered by kvm_linux_vm. Drives first-boot setup of the labadmin bootstrap
# user (local, non-AD) + SSH key so the control node can run domain_join_linux.
hostname: {{ linux_hostname }}
fqdn: {{ linux_fqdn }}
preserve_hostname: false
ssh_pwauth: true
chpasswd:
  expire: false
users:
  - name: {{ linux_admin_user }}
    groups: [adm, sudo]
    shell: /bin/bash
    lock_passwd: false
    # Deterministic salt (derived per-host from user+FQDN) so this seed renders
    # byte-identically every run — password_hash() with no salt mints a RANDOM
    # one each time, which made user-data (and the seed ISO built from it) report
    # 'changed' on every re-run. The salt is not a secret (the password itself is
    # vaulted); it only needs to be stable. hash('sha512') is hex ([0-9a-f]), a
    # subset of the crypt salt charset; sliced to the 16-char sha512-crypt max.
    passwd: "{{ linux_admin_password | password_hash('sha512', salt=((linux_admin_user ~ linux_fqdn) | hash('sha512'))[:16]) }}"
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    ssh_authorized_keys:
      - "{{ lookup('file', linux_ssh_pubkey_path) }}"
