#Requires -RunAsAdministrator
# Inline WinRM HTTPS bootstrap script (ADR-021).
# Invoked from Autounattend.xml's FirstLogonCommands by a small CMD wrapper that
# walks CD-ROM drive letters looking for this file.
#
# Logs to C:\Windows\Temp\bootstrap.log so post-mortem is trivial if WinRM
# never comes up.

$ErrorActionPreference = 'Stop'
$logPath = 'C:\Windows\Temp\bootstrap.log'
function Log($msg) {
    $stamp = (Get-Date -Format 'yyyy-MM-ddTHH:mm:ss')
    "$stamp $msg" | Out-File -FilePath $logPath -Append -Encoding utf8
}

try {
    Log "Bootstrap start (Computer=$env:COMPUTERNAME)"

    # Declarative belt-and-suspenders for isolated/gateway-less segments (Phase 6
    # Branch): the Network List Manager policy "Unidentified Networks = Private"
    # (well-known signature GUID below) makes Windows classify any network it cannot
    # identify as Private automatically, with no dependence on Set-NetConnectionProfile
    # timing. Ref: MS Learn "Network List Manager policies". Pure registry write, so it
    # cannot hit the 'Identifying...' race. Harmless on identified nets (DC/clients):
    # their networks are identified, so the unidentified-network policy never applies.
    Log "Set NLM policy: Unidentified Networks -> Private (deterministic for isolated nets)"
    $nlmUnidentified = 'HKLM:\SOFTWARE\Policies\Microsoft\Windows NT\CurrentVersion\NetworkList\Signatures\010103000F0000F0010000000F0000F0C967A3643C3AD745950DA7859209176EF5B87C875FA20DF21951640E807D7C24'
    New-Item -Path $nlmUnidentified -Force | Out-Null
    New-ItemProperty -Path $nlmUnidentified -Name 'Category' -PropertyType DWord -Value 1 -Force | Out-Null

    # Server 2025 24H2 regression: NLA may classify the network as Public
    # before/during this script's run, which silently disables WinRM rules
    # scoped to Domain/Private. Force the profile to Private up-front, then
    # ensure NlaSvc is auto-start (it's disabled by default on Server 2025).
    # Refs: techcommunity Server 2025 "always shows network as public" regression,
    # frankysweb, woshub, StefanScherer/packer-windows enable-winrm.ps1.
    #
    # ISOLATED-NETWORK race (Phase 6 Branch DC, found 2026-06-01): on a network with
    # no reachable gateway (e.g. ADDC02 on corp-branch before VyOS is up), NLA sits in
    # 'Identifying...' for tens of seconds after boot. Set-NetConnectionProfile THROWS
    # on an 'Identifying...' profile, and with $ErrorActionPreference='Stop' that
    # aborted bootstrap before the HTTPS listener was ever created (5985 default
    # listener up, 5986 never). Fix: retry while NLA settles, and treat a persistent
    # failure as NON-FATAL -- the WinRM HTTPS firewall rule below is '-Profile Any',
    # so reachability does not depend on the profile actually being Private.
    Log "Force network profile Private (best-effort; retries while NLA is 'Identifying')"
    $profileDeadline = (Get-Date).AddSeconds(120)
    do {
        $profilePending = $false
        foreach ($ncp in Get-NetConnectionProfile) {
            try {
                Set-NetConnectionProfile -InterfaceAlias $ncp.InterfaceAlias -NetworkCategory Private -ErrorAction Stop
                Log "  set Private on '$($ncp.InterfaceAlias)'"
            } catch {
                $profilePending = $true
                Log "  '$($ncp.InterfaceAlias)' not settable yet (NLA still identifying); will retry"
            }
        }
        if ($profilePending) { Start-Sleep -Seconds 5 }
    } while ($profilePending -and (Get-Date) -lt $profileDeadline)
    if ($profilePending) { Log "  WARNING: profile not set to Private before deadline; continuing (WinRM rule is -Profile Any)" }
    Log "Set NlaSvc StartupType Automatic"
    Set-Service -Name NlaSvc -StartupType Automatic -ErrorAction SilentlyContinue

    Log "Enable-PSRemoting -Force"
    Enable-PSRemoting -Force -SkipNetworkProfileCheck | Out-Null

    Log "Create self-signed cert CN=$env:COMPUTERNAME"
    $cert = New-SelfSignedCertificate `
        -CertStoreLocation 'Cert:\LocalMachine\My' `
        -DnsName $env:COMPUTERNAME `
        -NotAfter (Get-Date).AddYears(1) `
        -Provider 'Microsoft Software Key Storage Provider' `
        -Subject "CN=$env:COMPUTERNAME"
    Log "Cert thumbprint: $($cert.Thumbprint)"

    Log "Remove any pre-existing HTTPS listeners"
    Get-ChildItem -Path WSMan:\localhost\Listener |
        Where-Object { $_.Keys -match 'Transport=HTTPS' } |
        ForEach-Object { Remove-Item -Path $_.PSPath -Recurse -Force }

    Log "Create HTTPS listener on port {{ vm_winrm_port }}"
    New-Item -Path 'WSMan:\localhost\Listener' `
        -Address '*' `
        -Transport HTTPS `
        -Port {{ vm_winrm_port }} `
        -CertificateThumbprint $cert.Thumbprint `
        -Enabled $true `
        -Force | Out-Null

    Log "Open Windows firewall TCP {{ vm_winrm_port }}"
    if (-not (Get-NetFirewallRule -DisplayName 'WinRM HTTPS-In' -ErrorAction SilentlyContinue)) {
        New-NetFirewallRule `
            -DisplayName 'WinRM HTTPS-In' `
            -Direction Inbound `
            -Protocol TCP `
            -LocalPort {{ vm_winrm_port }} `
            -Action Allow `
            -Profile Any | Out-Null
    }

    Log "Enable Basic + NTLM auth for the WinRM service (lab-only)"
    Set-Item -Path 'WSMan:\localhost\Service\Auth\Basic' -Value $true -Force
    Set-Item -Path 'WSMan:\localhost\Service\AllowUnencrypted' -Value $false -Force

    Log "Restart WinRM service"
    Restart-Service -Name WinRM -Force

    Log "Bootstrap COMPLETE - listener summary:"
    (winrm enumerate winrm/config/listener) | Out-File -FilePath $logPath -Append -Encoding utf8
}
catch {
    Log "BOOTSTRAP FAILED: $($_.Exception.Message)"
    Log $_.ScriptStackTrace
    exit 1
}
