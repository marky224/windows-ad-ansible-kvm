<network>
  <name>{{ net.name }}</name>
{% if (net.forward | default('nat')) != 'isolated' %}
  <forward mode='{{ net.forward | default('nat') }}'>
    <nat>
      <port start='1024' end='65535'/>
    </nat>
  </forward>
{% endif %}
  <bridge name='{{ net.bridge }}' stp='on' delay='0'/>
  <mac address='{{ net.mac }}'/>
  <ip address='{{ net.host_ip }}' netmask='{{ net.netmask }}'/>
  {# DHCP intentionally omitted — DC owns DHCP (ADR-007); Branch uses VyOS dhcp-relay. #}
{#- isolated networks (no <forward>) carry no NAT: VyOS routes between subnets, ADR-052 -#}
</network>
