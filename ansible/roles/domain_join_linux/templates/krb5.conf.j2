# Managed by Ansible (domain_join_linux role). Minimal realm config; sssd/adcli
# resolve KDCs dynamically via DNS SRV records served by the DC.
[libdefaults]
    default_realm = {{ realm_domain | upper }}
    dns_lookup_realm = true
    dns_lookup_kdc = true
    rdns = false
    fcc-mit-ticketflags = true
    forwardable = true
    # AD KDCs (notably Server 2025) canonicalize the client principal in the
    # AS-REP; MIT krb5's default (canonicalize=false) then rejects the reply as
    # "KDC reply did not match expectations" and the realm/adcli join fails even
    # though preauth + AES256 decryption succeed. Requesting canonicalization
    # makes krb5 accept the returned principal. Proven via kinit bake-off; the
    # twin sssd setting (krb5_canonicalize) covers steady-state auth. See ADR.
    canonicalize = {{ realm_krb5_canonicalize | default(true) | lower }}

[realms]
    {{ realm_domain | upper }} = {
        kdc = {{ corp_subnet.dc_ip }}
        admin_server = {{ corp_subnet.dc_ip }}
        default_domain = {{ realm_domain }}
    }

[domain_realm]
    .{{ realm_domain }} = {{ realm_domain | upper }}
    {{ realm_domain }} = {{ realm_domain | upper }}
